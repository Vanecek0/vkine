// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Vyřešit možnosti migrace přes localhost
datasource db {
  //provider = "mysql"
  //url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = env("LOCAL_DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @default("")
  email     String    @unique @default("")
  password  String    @default("")
  isActive  Boolean   @default(true)
  provider  String    @default("credentials")
  createdAt DateTime  @default(now())
  userData  UserData?
  List      List?     @relation(fields: [listId], references: [id])
  listId    Int?
}

model UserData {
  id               Int      @id @unique
  user             User     @relation(fields: [id], references: [id])
  nickname         String   @default("")
  firstname        String   @default("")
  lastname         String   @default("")
  bio              String   @default("")
  birthday         DateTime @default(now())
  phoneNumber      String   @default("")
  country          String   @default("")
  gender           Int      @default(0)
  profileImage     String   @default("")
  profileWallpaper String   @default("")
  facebook         String   @default("")
  instagram        String   @default("")
  twitterX         String   @default("")
  youtube          String   @default("")
  homepage         String   @default("")
  updatedAt        DateTime @default(now())
  List             List[]
}

model List {
  id            Int      @id @default(autoincrement())
  author        UserData @relation(fields: [authorId], references: [id])
  authorId      Int
  title         String   @default("")
  description   String   @default("")
  movies        String   @default("")
  tvs           String   @default("")
  people        String   @default("")
  isPrivate     Boolean  @default(false)
  isPublished   Boolean  @default(true)
  views         Int      @default(0)
  likes         Int      @default(0)
  shares        Int      @default(0)
  listWallpaper String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  User          User[]
}